# Copy this file to .env locally if you want shell helpers to load it.
# Do not commit your real .env file.

# Network / proxy
ASTRO_PROXY=http://127.0.0.1:7890

# NASA ADS; utils.py can also read ~/.ads/dev_key.
ADS_DEV_KEY=

# Gaia archive DataLink authentication.
GAIA_TOKEN=

# LAMOST DR12 / pylamost / My Data Disk Requests.
LAMOST_DR=dr12
LAMOST_TOKEN=
LAMOST_FTP_SERVER=ftp3.lamost.org
LAMOST_FTP_USER=
LAMOST_FTP_PASSWORD=

# Optional local data paths.
BAYESTAR2019_PATH=
KOA_LOCAL_ROOT=
