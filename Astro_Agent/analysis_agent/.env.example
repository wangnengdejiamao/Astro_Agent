# Copy values into your shell environment or a private .env file that is not committed.
# Do not put live API keys in source-controlled files.

ASTRO_AGENT_MODEL_PROVIDER=fox
ASTRO_AGENT_MODEL=gpt-5.5
ASTRO_AGENT_REASONING_EFFORT=high
ASTRO_AGENT_DISABLE_RESPONSE_STORAGE=true
FOX_BASE_URL=https://dm-fox.rjj.cc/codex/v1
FOX_WIRE_API=responses
OPENAI_API_KEY=

# Alternative provider
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_WIRE_API=chat_completions
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

# Kimi / Moonshot OpenAI-compatible provider
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_WIRE_API=chat_completions
KIMI_MODEL=kimi-k2-latest
KIMI_API_KEY=

# Optional Claude Code delegate. Leave empty to disable.
ASTRO_AGENT_CLAUDE_BIN=claude
ASTRO_AGENT_SUBPROC_TIMEOUT=900
