# DeepSeek / OpenAI-compatible LLM API
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=DeepSeek-V4-Pro
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=1200

# OpenAI-compatible aliases are also supported by utils/call_llm_api.py
OPENAI_API_KEY=${LLM_API_KEY}
OPENAI_BASE_URL=${LLM_BASE_URL}
OPENAI_MODEL=${LLM_MODEL}

# Project paths
PROJECT_DIR=.
PROJECT_ROOT=.
OUTPUT_DIR=output
GRAPHRAG_DIR=output
GRAPH_INDEX_CACHE_DIR=cache/graph_index
GRAPH_RETRIEVER_CACHE_DIR=cache/graph_retriever

# Optional Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
